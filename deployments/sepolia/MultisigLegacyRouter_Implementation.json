    "kind": "dev",
    "methods": {
      "activeLegacy(uint256)": {
        "details": "Active legacy, call this function when the safewallet is eligible for activation.",
        "params": {
          "legacyId_": "legacy id"
        }
      },
      "checkActiveLegacy(uint256)": {
        "details": "Check activation conditions. This activation conditions is current time >= last transaction of safe wallet + lackOfOutgoingTxRange.",
        "params": {
          "legacyId_": "legacy id"
        },
        "returns": {
          "_0": "bool true if eligible for activation, false otherwise"
        }
      },
      "createLegacy(address,(string,string,string[],address[]),(uint128,uint128),uint256,bytes)": {
        "details": "Create new legacy and guard.",
        "params": {
          "extraConfig_": "include minRequireSignature, lackOfOutgoingTxRange",
          "mainConfig_": "include name, note, nickname[], beneficiaries[]",
          "safeWallet": "safeWallet address"
        },
        "returns": {
          "_0": "address legacy address",
          "_1": "address guard address"
        }
      },
      "getNextLegacyAddress(address)": {
        "details": "Get next legacy address that would be created for a sender",
        "params": {
          "sender_": "The address of the sender"
        },
        "returns": {
          "_0": "address The next legacy address that would be created"
        }
      },
      "setActivationTrigger(uint256,uint256)": {
        "details": "Set lackOfOutgoingTxRange legacy, call this function if only mofify lackOfOutgoingTxRange to save gas for user.",
        "params": {
          "lackOfOutgoingTxRange_": "lackOfOutgoingTxRange",
          "legacyId_": "legacy id"
        }
      },
      "setLegacyBeneficiaries(uint256,string[],address[],uint128)": {
        "details": "Set beneficiaries[], minRequiredSignatures_ legacy, call this function if only modify beneficiaries[], minRequiredSignatures to save gas for user.",
        "params": {
          "beneficiaries_": "beneficiaries []",
          "legacyId_": "legacy id",
          "minRequiredSignatures_": "minRequiredSignatures",
          "nickName_": "nick name[]"
        }
      },
      "setLegacyConfig(uint256,(string,string,string[],address[]),(uint128,uint128))": {
        "details": "Set legacy config include beneficiaries, minRequireSignatures, lackOfOutgoingTxRange.",
        "params": {
          "extraConfig_": "include minRequireSignature, lackOfOutgoingTxRange",
          "legacyId_": "legacy Id",
          "mainConfig_": "include name, note, nickname[], beneficiaries[]"
        }
      },
      "setNameNote(uint256,string,string)": {
        "details": "Set name and note legacy, call this function if only modify name and note to save gas for user.",
        "params": {
          "legacyId_": "legacy id",
          "name_": "name legacy",
          "note_": "note legacy"
        }
      }
    },
