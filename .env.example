# Sepolia RPC for deployments (--network sepolia) and for local forking.
# When fork-block.json exists with network "sepolia", "hardhat node" forks from Sepolia;
# if unset, the config uses https://rpc.sepolia.org. Set this for a dedicated RPC (e.g. Infura/Alchemy).
# SEPOLIA_RPC_URL =
# RPC =

# When forking (e.g. hardhat with fork-block.json), set to the forked network name
# so deploy scripts use that network's external addresses (Uniswap, Chainlink, etc.).
# Example: EXTERNAL_ADDRESSES_NETWORK=sepolia
# EXTERNAL_ADDRESSES_NETWORK =

